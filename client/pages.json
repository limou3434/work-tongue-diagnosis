{
	"easycom": {
		"autoscan": true,
		"custom": {
			"^van-(.*)": "@vant/weapp/(.*)/",
			"^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
		}
	},
	"pages": [
